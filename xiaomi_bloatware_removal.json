{
  "meta": {
    "title": "Xiaomi HyperOS / MIUI — Bloatware Removal Database",
    "source": "XDA Forums · Technastic · GitHub community",
    "tested_on": "HyperOS 1/2 | NON-ROOT (ADB only)",
    "legend": {
      "SAFE": "Xóa/tắt an toàn, không ảnh hưởng hệ thống",
      "RISKY": "Cần cân nhắc, có thể ảnh hưởng tính năng",
      "KEEP": "KHÔNG XÓA",
      "Tracking": "Thu thập dữ liệu / Telemetry",
      "Google Bloat": "Ứng dụng Google cài sẵn không cần thiết"
    }
  },
  "quick_guide": {
    "step1_prepare": [
      "Bật Developer Options: Settings → About phone → Nhấn 7 lần vào OS version",
      "Bật USB Debugging trong Developer Options",
      "Tải Android SDK Platform Tools: developer.android.com/tools/releases/platform-tools",
      "Giải nén vào thư mục C:\\adb (hoặc bất kỳ đâu)",
      "Cắm điện thoại vào PC, mở CMD trong thư mục platform-tools",
      "Chạy: adb devices → Cho phép trên điện thoại khi được hỏi"
    ],
    "step2_commands": {
      "disable": "adb shell pm disable-user --user 0 <package>",
      "uninstall": "adb shell pm uninstall -k --user 0 <package>",
      "restore_disabled": "adb shell pm enable --user 0 <package>",
      "restore_uninstalled": "adb shell cmd package install-existing <package>"
    },
    "step3_verify": [
      "Khởi động lại điện thoại và dùng bình thường 30 phút",
      "Nếu có lỗi: dùng restore command hoặc factory reset để rollback",
      "Factory reset sẽ restore toàn bộ app đã uninstall bằng --user 0"
    ],
    "gui_tools": [
      {
        "name": "ADB AppControl 1.8.6",
        "platform": "Windows GUI",
        "note": "Recommended nhất"
      },
      {
        "name": "Universal Android Debloater (UAD)",
        "platform": "Cross platform",
        "note": "Open source"
      },
      {
        "name": "Canta",
        "platform": "Android app",
        "note": "Dùng Shizuku, không cần PC"
      }
    ],
    "do_not_remove": [
      "com.miui.core",
      "com.miui.securitycenter",
      "com.google.android.gms",
      "com.android.phone",
      "com.android.contacts",
      "com.android.settings"
    ]
  },
